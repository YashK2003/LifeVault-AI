# =============================================
# LifeVault Environment Configuration
# =============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git (it's in .gitignore)
# =============================================

# --- Required ---

# Google Gemini API Key
# Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-api-key-here

# --- Optional ---

# Gemini Model for agent LLM calls (default: gemini-2.5-flash)
# Cost: ~$0.15/M input tokens, ~$0.60/M output tokens
# Options: gemini-2.5-flash (recommended), gemini-2.0-flash, gemini-2.5-pro
GOOGLE_GENAI_MODEL=gemini-2.5-flash

# Set to TRUE to use Vertex AI instead of AI Studio
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Vault database path (default: vault.db in project root)
# VAULT_DB_PATH=/path/to/vault.db
